      <virtualTable>
        <name>records_buffer</name>
        <sql>SELECT ST_Buffer(coords_wgs::geography, gps_coords_precision)::geometry AS buffer , validation_status, TO_CHAR(datum, &apos;YYYY-MM-DD&apos;) AS datum, string_agg(auth.surname, &apos;, &apos;) AS name&#xd;
FROM atlas.records AS rec,&#xd;
	atlas.records_authors AS rel,&#xd;
	atlas.authors AS auth&#xd;
WHERE    &#xd;
   rec.taxon_id = %TAXON_ID% AND&#xd;
   rel.records_id = rec.id AND&#xd;
   auth.id = rel.authors_id&#xd;
GROUP BY rec.id
</sql>
